{
  "datasets": [
    {
      "name": "44ca3314",
      "displayName": "Location Data",
      "queryLines": [
        "SELECT latitude, longitude, `GHG emissions mtons CO2e` as Emissions FROM workspace.default.emissions_data"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "9f40f432",
      "displayName": "Total Emissions Per State",
      "queryLines": [
        "SELECT state_abbr,\r\n",
        "    SUM(CAST(\r\n",
        "      REPLACE(`GHG emissions mtons CO2e`, ',', '')\r\n",
        "      AS DOUBLE\r\n",
        "    )) AS Total_Emissions\r\n",
        "    FROM emissions_data\r\n",
        "    GROUP BY state_abbr\r\n",
        "    ORDER BY Total_Emissions DESC\r\n",
        "    LIMIT 10"
      ]
    },
    {
      "name": "bcbd3864",
      "displayName": "Emissions per Person",
      "queryLines": [
        "SELECT county_state_name, population, CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE) / NULLIF(CAST(REPLACE(population, ',', '') AS DOUBLE), 0) AS Emissions_per_person FROM workspace.default.emissions_data ORDER BY Emissions_per_person DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "54f47ecd",
      "displayName": "Country Shamming",
      "queryLines": [
        "SELECT county_state_name,\r\n",
        "       population,\r\n",
        "       CAST(\r\n",
        "         REPLACE(`GHG emissions mtons CO2e`, ',', '')\r\n",
        "         AS DOUBLE) AS Total_emissions \r\n",
        "FROM emissions_data  \r\n",
        "ORDER BY Total_Emissions DESC\r\n",
        "LIMIT 10"
      ]
    }
  ],
